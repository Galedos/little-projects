def capture():
    sock =  socket.socket(
    socket.AF_PACKET,
    socket.SOCK_RAW,
    socket.ntohs(0x0003),
    )
    sock.bind((choices[chosen], 0))
    while True:
        packet = sock.recv(65535)
        packet_queue.put(packet)

def identify():
    temp = ""
    i = 0
    packet_info = {
            "header": "",
            "packtype": "",
            "raw": "",
            "ascii": "",
            "length": 0,
        }
    while True:
        packet = packet_queue.get()
        packet_info["length"] = len(packet)
        protocol = packet[23]
        for bytes in packet:
            if 32 <= bytes <= 126:
                parsed = chr(bytes)
            else:
                parsed = "."
            temp += parsed 
            
        if len(packet) == len(temp):
            packet_info["ascii"] = temp
            
        if packet[12:14] == b'\x08\x00':
                packet_info["header"] = "IPv4"
                if protocol == 6:
                    packet_info["packtype"] = "TCP"
                elif protocol == 17:
                    packet_info["packtype"] = "UDP"
                elif protocol == 1:
                    packet_info["packtype"] = "ICMP"
                    
        elif packet[12:14] == b'\x86\xDD':
                packet_info["header"] = "IPv6"
        elif packet[12:14] == b'\x08\x06':
                packet_info["header"] = "ARP"
        temp = ""

